generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "sqlite"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  ARTIST
  CUSTOMER
}

enum FulfillmentMode {
  ARTIST_SELF_DELIVERY
  PLATFORM_DELIVERY
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  SHIPPED
  DELIVERED
}

enum NotificationType {
  ORDER
  PAYMENT
  SHIPMENT
  SYSTEM
}

enum StoreStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum BadgeType {
  FIRST_PURCHASE
  KANTO_CHAMPION
  EARLY_SUPPORTER
  TOP_SUPPORTER
  SUBSCRIBER
}

// ─── Pathway Models (Submissions) ────────────────────────────────────────────

model MusicSubmission {
  id            String   @id @default(cuid())
  bandName      String
  realName      String
  email         String
  spotifyLink   String?
  soundcloudLink String?
  city          String
  genre         String?
  message       String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SponsorInquiry {
  id            String   @id @default(cuid())
  businessName  String
  contactName   String
  email         String
  phone         String?
  plan          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Donation {
  id            String   @id @default(cuid())
  name          String?
  email         String?
  amount        Float
  tier          String
  message       String?
  createdAt     DateTime @default(now())
}

// ─── Kanto Fund Tracker ──────────────────────────────────────────────────────

model KantoFundEntry {
  id          Int      @id @default(autoincrement())
  source      String   // "Sponsorship", "Donation", "Other"
  description String
  amount      Float
  quarter     String   // e.g. "Q1-2026"
  createdAt   DateTime @default(now())
}

// ─── User & Auth ─────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String?
  name      String
  role      UserRole @default(CUSTOMER)
  phone     String?
  avatar    String?
  provider  String   @default("credentials") // "credentials", "google", "facebook"
  address   String?  // JSON: default shipping address
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artistProfile   ArtistProfile?
  orders          Order[]
  cartItems       Cart[]
  reviews         Review[]
  notifications   Notification[]
  digitalPurchases DigitalPurchase[]
  tipsSent        Tip[]
  badges          UserBadge[]
}

// ─── Artist ──────────────────────────────────────────────────────────────────

model ArtistProfile {
  id                      Int             @id @default(autoincrement())
  userId                  Int             @unique
  bandName                String
  realName                String
  genre                   String?
  city                    String
  bio                     String?
  spotifyLink             String?
  soundcloudLink          String?
  socialLinks             String?         // JSON string: { facebook, instagram, tiktok, etc. }
  imageUrl                String?
  stripeAccountId         String?
  stripeOnboardingComplete Boolean         @default(false)
  isVerified              Boolean         @default(false)
  storeStatus             StoreStatus     @default(PENDING)   // Admin must approve store access
  storeRejectedReason     String?         // Reason if rejected
  totalSales              Float           @default(0)          // Cached total
  totalAirplays           Int             @default(0)          // Cached radio airplay count
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  products    Product[]
  orderItems  OrderItem[]
  tips        Tip[]

  @@index([userId])
  @@index([storeStatus])
}

// ─── Product ─────────────────────────────────────────────────────────────────

model Product {
  id              Int             @id @default(autoincrement())
  artistId        Int
  name            String
  description     String
  price           Float
  compareAtPrice  Float?          // for showing discounts (strikethrough)
  category        String          // e.g., "T-Shirt", "Hoodie", "Sticker", "Album", "EP"
  productType     ProductType     @default(PHYSICAL)         // PHYSICAL or DIGITAL
  images          String          // JSON string array of image URLs
  sizes           String?         // JSON string array: ["S","M","L","XL"]
  colors          String?         // JSON string array: ["Black","White"]
  stock           Int             @default(0)
  fulfillmentMode FulfillmentMode @default(PLATFORM_DELIVERY)
  shippingFee     Float           @default(0)
  isActive        Boolean         @default(true)
  isStation       Boolean         @default(false)            // true = TKR official merch (revenue goes to station)
  isFlagged       Boolean         @default(false)            // content moderation flag
  flagReason      String?         // reason for flagging
  downloadUrl     String?         // for digital products: file URL
  fileSize        String?         // for digital products: e.g. "45MB"
  fileFormat      String?         // for digital products: e.g. "ZIP", "MP3"
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  artist            ArtistProfile    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  orderItems        OrderItem[]
  cartItems         Cart[]
  reviews           Review[]
  digitalPurchases  DigitalPurchase[]

  @@index([artistId])
  @@index([category])
  @@index([isActive])
  @@index([productType])
  @@index([isStation])
}

// ─── Order ───────────────────────────────────────────────────────────────────

model Order {
  id                 Int          @id @default(autoincrement())
  orderNumber        String       @unique
  customerId         Int?
  guestEmail         String?      // for guest checkout
  guestName          String?      // for guest checkout
  status             OrderStatus  @default(PENDING)
  totalAmount        Float
  platformRevenue    Float        @default(0)  // station merch revenue only
  artistRevenueTotal Float        @default(0)  // sum of artist cuts (info only, money goes directly via Stripe)
  shippingAddress    String       // JSON object: { name, line1, city, province, postalCode, phone }
  paymentIntentId    String?
  trackingNumber     String?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  customer   User?       @relation(fields: [customerId], references: [id])
  orderItems OrderItem[]

  @@index([customerId])
  @@index([guestEmail])
  @@index([orderNumber])
  @@index([status])
}

// ─── Order Item ──────────────────────────────────────────────────────────────

model OrderItem {
  id              Int             @id @default(autoincrement())
  orderId         Int
  productId       Int
  artistId        Int
  productName     String
  productImage    String?
  quantity        Int
  unitPrice       Float           // price snapshot at purchase time
  subtotal        Float           // quantity * unitPrice
  fulfillmentMode FulfillmentMode
  shippingFee     Float           @default(0)
  status          OrderItemStatus @default(PENDING)
  isStationMerch  Boolean         @default(false)  // true = TKR station merch
  isDigital       Boolean         @default(false)  // digital product flag
  downloadUrl     String?         // snapshot of download URL at purchase time

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  artist  ArtistProfile @relation(fields: [artistId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([artistId])
}

// ─── Cart ────────────────────────────────────────────────────────────────────

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int?
  sessionId String?  // for guest checkout (session-based cart)
  productId Int
  quantity  Int
  size      String?  // selected size e.g. "M", "XL"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  customerId Int
  rating    Int      // 1 to 5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer User    @relation(fields: [customerId], references: [id])

  @@index([productId])
  @@index([customerId])
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// ─── Digital Purchase (Download Vault) ──────────────────────────────────────

model DigitalPurchase {
  id          Int      @id @default(autoincrement())
  userId      Int
  productId   Int
  orderId     Int
  downloadUrl String   // the file URL
  fileName    String?  // display name
  fileFormat  String?  // e.g. "ZIP", "MP3"
  accessCode  String   @unique  // unique download code for shareable links
  downloadCount Int    @default(0)
  maxDownloads Int     @default(10) // max downloads allowed
  expiresAt   DateTime?  // optional expiration
  createdAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId, orderId])
  @@index([userId])
  @@index([accessCode])
}

// ─── Tip (Direct Artist Support) ────────────────────────────────────────────

model Tip {
  id            Int      @id @default(autoincrement())
  fromUserId    Int?
  guestEmail    String?
  guestName     String?
  artistId      Int
  amount        Float
  message       String?
  paymentIntentId String?
  createdAt     DateTime @default(now())

  artist ArtistProfile @relation(fields: [artistId], references: [id])
  user   User?         @relation(fields: [fromUserId], references: [id])

  @@index([artistId])
  @@index([fromUserId])
}

// ─── Badge (Gamification) ───────────────────────────────────────────────────

model Badge {
  id        Int       @id @default(autoincrement())
  type      BadgeType @unique
  name      String    // e.g. "Kanto Champion"
  icon      String    // emoji or icon identifier
  description String  // e.g. "Awarded for making 5+ purchases"
  threshold Int       // number of actions needed
  createdAt DateTime  @default(now())

  users UserBadge[]
}

model UserBadge {
  id        Int      @id @default(autoincrement())
  userId    Int
  badgeId   Int
  earnedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
}
