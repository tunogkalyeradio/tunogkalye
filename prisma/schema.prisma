generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "sqlite"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  ARTIST
  CUSTOMER
}

enum FulfillmentMode {
  ARTIST_SELF_DELIVERY
  PLATFORM_DELIVERY
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  SHIPPED
  DELIVERED
}

enum NotificationType {
  ORDER
  PAYMENT
  SHIPMENT
  SYSTEM
}

// ─── Existing Models (Pathway) ────────────────────────────────────────────────

model MusicSubmission {
  id            String   @id @default(cuid())
  bandName      String
  realName      String
  email         String
  spotifyLink   String?
  soundcloudLink String?
  city          String
  genre         String?
  message       String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SponsorInquiry {
  id            String   @id @default(cuid())
  businessName  String
  contactName   String
  email         String
  phone         String?
  plan          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Donation {
  id            String   @id @default(cuid())
  name          String?
  email         String?
  amount        Float
  tier          String
  message       String?
  createdAt     DateTime @default(now())
}

// ─── User & Auth ─────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(CUSTOMER)
  phone     String?
  avatar    String?
  address   String?  // JSON: default shipping address
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artistProfile   ArtistProfile?
  orders          Order[]
  cartItems       Cart[]
  reviews         Review[]
  notifications   Notification[]
}

// ─── Artist ──────────────────────────────────────────────────────────────────

model ArtistProfile {
  id                      Int             @id @default(autoincrement())
  userId                  Int             @unique
  bandName                String
  realName                String
  genre                   String?
  city                    String
  bio                     String?
  spotifyLink             String?
  soundcloudLink          String?
  socialLinks             String?         // JSON string: { facebook, instagram, tiktok, etc. }
  imageUrl                String?
  stripeAccountId         String?
  stripeOnboardingComplete Boolean         @default(false)
  isVerified              Boolean         @default(false)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  products    Product[]
  orderItems  OrderItem[]

  @@index([userId])
}

// ─── Product ─────────────────────────────────────────────────────────────────

model Product {
  id              Int             @id @default(autoincrement())
  artistId        Int
  name            String
  description     String
  price           Float
  compareAtPrice  Float?          // for showing discounts (strikethrough)
  category        String          // e.g., "T-Shirt", "Hoodie", "Sticker", "Digital"
  images          String          // JSON string array of image URLs
  sizes           String?         // JSON string array: ["S","M","L","XL"]
  colors          String?         // JSON string array: ["Black","White"]
  stock           Int             @default(0)
  fulfillmentMode FulfillmentMode @default(PLATFORM_DELIVERY)
  shippingFee     Float           @default(0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  artist      ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  cartItems   Cart[]
  reviews     Review[]

  @@index([artistId])
  @@index([category])
  @@index([isActive])
}

// ─── Order ───────────────────────────────────────────────────────────────────

model Order {
  id                 Int          @id @default(autoincrement())
  customerId         Int
  orderNumber        String       @unique
  status             OrderStatus  @default(PENDING)
  totalAmount        Float
  platformRevenue    Float        @default(0)  // 10% platform cut
  artistRevenueTotal Float        @default(0)  // sum of artist cuts
  shippingAddress    String       // JSON object: { name, line1, city, province, postalCode, phone }
  paymentIntentId    String?
  trackingNumber     String?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  customer   User        @relation(fields: [customerId], references: [id])
  orderItems OrderItem[]

  @@index([customerId])
  @@index([orderNumber])
  @@index([status])
}

// ─── Order Item ──────────────────────────────────────────────────────────────

model OrderItem {
  id              Int             @id @default(autoincrement())
  orderId         Int
  productId       Int
  artistId        Int
  productName     String
  productImage    String?
  quantity        Int
  unitPrice       Float           // price snapshot at purchase time
  subtotal        Float           // quantity * unitPrice
  platformCut     Float           // 10% of subtotal
  artistCut       Float           // 90% of subtotal
  fulfillmentMode FulfillmentMode
  shippingFee     Float           @default(0)
  status          OrderItemStatus @default(PENDING)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  artist  ArtistProfile @relation(fields: [artistId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([artistId])
}

// ─── Cart ────────────────────────────────────────────────────────────────────

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  quantity  Int
  size      String?  // selected size e.g. "M", "XL"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  customerId Int
  rating    Int      // 1 to 5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer User    @relation(fields: [customerId], references: [id])

  @@index([productId])
  @@index([customerId])
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}
